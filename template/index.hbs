<!DOCTYPE html>
<html lang="hu">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{cim}} — Karrierküldetés</title>
{{#if standalone}}
<style>
body {
  margin: 0; padding: 40px 20px; min-height: 100vh;
  background-color: var(--kk-page-bg, #cdd0e1);
  background-image: radial-gradient(circle, rgba(0,0,0,0.06) 1px, transparent 1px);
  background-size: 22px 22px;
}
</style>
{{/if}}
<style>
{{{css}}}
</style>
</head>
<body>
<div class="kk-root" data-tema="{{tema}}">
  <header class="kk-header">
    <div class="kk-header-label">Karrier küldetés</div>
    <h1 class="kk-title">{{cim}}</h1>
    {{#if leiras}}<p class="kk-leiras">{{leiras}}</p>{{/if}}
  </header>

  <div class="kk-flow" id="kk-flow-{{slug}}">
    <div class="kk-grid">
      {{#each kurzusok}}
        {{#if kesz}}
        <a class="kk-card kk-card--kesz" href="{{url}}" data-idx="{{@index}}" target="_blank" rel="noopener">
          <div class="kk-card-num">{{kkNum @index}}</div>
          <div class="kk-card-ikon">{{ikon}}</div>
          <div class="kk-card-cim">{{cim}}</div>
          {{#if hossz}}<div class="kk-card-hossz">{{kkHossz hossz}}</div>{{/if}}
        </a>
        {{else}}
        <div class="kk-card kk-card--hamarosan" data-idx="{{@index}}" aria-disabled="true">
          <div class="kk-card-num">{{kkNum @index}}</div>
          <div class="kk-card-badge">Hamarosan</div>
          <div class="kk-card-ikon">{{ikon}}</div>
          <div class="kk-card-cim">{{cim}}</div>
          {{#if hossz}}<div class="kk-card-hossz">{{kkHossz hossz}}</div>{{/if}}
        </div>
        {{/if}}
      {{/each}}
    </div>
    <svg class="kk-arrows" aria-hidden="true"></svg>
  </div>
  <div class="kk-vegcel-wrap">
    <div class="kk-card kk-card--vegcel" id="kk-vegcel-{{slug}}">
      <div class="kk-card-cim">{{vegcel.cim}}</div>
    </div>
  </div>
  <svg class="kk-arrows kk-arrows--vegcel" id="kk-vegcel-arrow-{{slug}}" aria-hidden="true"></svg>
</div>

<script>
(function(){
  var root = document.getElementById('kk-flow-{{slug}}');
  if (!root) return;
  var grid = root.querySelector('.kk-grid');
  var svg = root.querySelector('.kk-arrows');
  var SVG_NS = 'http://www.w3.org/2000/svg';

  function applySnakeOrder() {
    var style = window.getComputedStyle(grid);
    var cols = style.gridTemplateColumns.split(' ').length;
    var cards = Array.prototype.slice.call(grid.children);
    cards.forEach(function(c){ c.style.order = ''; c.style.gridColumn = ''; c.style.gridRow = ''; c.dataset.kkRow = ''; c.dataset.kkCol = ''; });
    cards.forEach(function(card, i) {
      var row = Math.floor(i / cols);
      var colInRow = i % cols;
      var visualCol = (row % 2 === 0) ? colInRow : (cols - 1 - colInRow);
      card.style.gridColumn = (visualCol + 1).toString();
      card.style.gridRow = (row + 1).toString();
      card.dataset.kkRow = row;
      card.dataset.kkCol = visualCol;
      card.dataset.kkSeq = i;
    });
  }

  function drawArrows() {
    while (svg.firstChild) svg.removeChild(svg.firstChild);
    var rect = root.getBoundingClientRect();
    svg.setAttribute('width', rect.width);
    svg.setAttribute('height', rect.height);
    svg.setAttribute('viewBox', '0 0 ' + rect.width + ' ' + rect.height);

    var cards = Array.prototype.slice.call(grid.children)
      .sort(function(a, b) { return parseInt(a.dataset.kkSeq || 999) - parseInt(b.dataset.kkSeq || 999); });

    var PAD = 6;       // gap between card edge and arrow start/tip
    var HEAD_L = 16;   // arrowhead length
    var HEAD_W = 14;   // arrowhead full width

    for (var i = 0; i < cards.length - 1; i++) {
      var from = cards[i].getBoundingClientRect();
      var to = cards[i+1].getBoundingClientRect();
      var sameRow = cards[i].dataset.kkRow === cards[i+1].dataset.kkRow;

      var isDisabled = cards[i].classList.contains('kk-card--hamarosan');
      var color = isDisabled ? getComputedStyle(root).getPropertyValue('--kk-card-bg-disabled').trim()
                             : getComputedStyle(root).getPropertyValue('--kk-card-bg').trim();

      var sx, sy, ex, ey, hd;

      if (sameRow) {
        var row = parseInt(cards[i].dataset.kkRow);
        var ltr = (row % 2 === 0);
        sy = from.top + from.height / 2 - rect.top;
        ey = to.top + to.height / 2 - rect.top;
        if (ltr) {
          sx = from.right - rect.left + PAD;
          ex = to.left - rect.left - PAD;
        } else {
          sx = from.left - rect.left - PAD;
          ex = to.right - rect.left + PAD;
        }
        // shaft ends at arrowhead base
        var dir = ex > sx ? 1 : -1;
        var shaftEnd = ex - dir * HEAD_L;
        // shaft
        var shaft = document.createElementNS(SVG_NS, 'line');
        shaft.setAttribute('x1', sx);
        shaft.setAttribute('y1', sy);
        shaft.setAttribute('x2', shaftEnd);
        shaft.setAttribute('y2', ey);
        shaft.setAttribute('class', 'kk-arrow-line');
        shaft.setAttribute('stroke', color);
        svg.appendChild(shaft);
        // arrowhead
        var hw = HEAD_W / 2;
        hd = document.createElementNS(SVG_NS, 'polygon');
        hd.setAttribute('points',
          shaftEnd + ',' + (ey - hw) + ' ' +
          ex + ',' + ey + ' ' +
          shaftEnd + ',' + (ey + hw));
        hd.setAttribute('fill', color);
        svg.appendChild(hd);
      } else {
        // vertical — straight down from `from` center
        var fx = (from.left + from.right) / 2 - rect.left;
        sy = from.bottom - rect.top + PAD;
        ey = to.top - rect.top - PAD;
        var shaftEndY = ey - HEAD_L;
        // shaft
        var vshaft = document.createElementNS(SVG_NS, 'line');
        vshaft.setAttribute('x1', fx);
        vshaft.setAttribute('y1', sy);
        vshaft.setAttribute('x2', fx);
        vshaft.setAttribute('y2', shaftEndY);
        vshaft.setAttribute('class', 'kk-arrow-line');
        vshaft.setAttribute('stroke', color);
        svg.appendChild(vshaft);
        // arrowhead
        var vhw = HEAD_W / 2;
        hd = document.createElementNS(SVG_NS, 'polygon');
        hd.setAttribute('points',
          (fx - vhw) + ',' + shaftEndY + ' ' +
          fx + ',' + ey + ' ' +
          (fx + vhw) + ',' + shaftEndY);
        hd.setAttribute('fill', color);
        svg.appendChild(hd);
      }
    }
  }

  function drawVegcelArrow() {
    var vegcel = document.getElementById('kk-vegcel-{{slug}}');
    var vegSvg = document.getElementById('kk-vegcel-arrow-{{slug}}');
    if (!vegcel || !vegSvg) return;
    while (vegSvg.firstChild) vegSvg.removeChild(vegSvg.firstChild);

    var kkRoot = root.closest('.kk-root');
    var rootRect = kkRoot.getBoundingClientRect();
    vegSvg.setAttribute('width', rootRect.width);
    vegSvg.setAttribute('height', rootRect.height);
    vegSvg.setAttribute('viewBox', '0 0 ' + rootRect.width + ' ' + rootRect.height);

    // Find last card in snake order
    var cards = Array.prototype.slice.call(grid.children)
      .sort(function(a, b) { return parseInt(a.dataset.kkSeq || 999) - parseInt(b.dataset.kkSeq || 999); });
    if (cards.length === 0) return;
    var lastCard = cards[cards.length - 1];
    var from = lastCard.getBoundingClientRect();
    var to = vegcel.getBoundingClientRect();

    var isDisabled = lastCard.classList.contains('kk-card--hamarosan');
    var color = isDisabled ? getComputedStyle(kkRoot).getPropertyValue('--kk-card-bg-disabled').trim()
                           : getComputedStyle(kkRoot).getPropertyValue('--kk-card-bg').trim();

    var PAD = 6;
    var HEAD_L = 16;
    var HEAD_W = 14;

    var fx = (from.left + from.right) / 2 - rootRect.left;
    var tx = (to.left + to.right) / 2 - rootRect.left;
    var sy = from.bottom - rootRect.top + PAD;
    var ey = to.top - rootRect.top - PAD;
    var shaftEndY = ey - HEAD_L;

    var vshaft = document.createElementNS(SVG_NS, 'line');
    vshaft.setAttribute('x1', fx);
    vshaft.setAttribute('y1', sy);
    vshaft.setAttribute('x2', tx);
    vshaft.setAttribute('y2', shaftEndY);
    vshaft.setAttribute('class', 'kk-arrow-line');
    vshaft.setAttribute('stroke', color);
    vegSvg.appendChild(vshaft);

    var vhw = HEAD_W / 2;
    var hd = document.createElementNS(SVG_NS, 'polygon');
    hd.setAttribute('points',
      (tx - vhw) + ',' + shaftEndY + ' ' +
      tx + ',' + ey + ' ' +
      (tx + vhw) + ',' + shaftEndY);
    hd.setAttribute('fill', color);
    vegSvg.appendChild(hd);
  }

  function update() { applySnakeOrder(); drawArrows(); drawVegcelArrow(); }
  update();
  if (window.ResizeObserver) {
    new ResizeObserver(update).observe(root.closest('.kk-root'));
  } else {
    window.addEventListener('resize', update);
  }
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(update);
  }
  setTimeout(update, 100);
  setTimeout(update, 500);
})();
</script>
</body>
</html>
